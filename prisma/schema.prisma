generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Department {
  department_id   Int    @id @default(autoincrement())
  department_name String @unique(map: "department_name") @db.VarChar(100)
  User            User[]
}

model Notification {
  notification_id Int       @id @default(autoincrement())
  message         String    @db.Text
  user_id         Int?
  task_id         Int?
  created_at      DateTime? @default(now()) @db.DateTime(0)
  User            User?     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "Notification_ibfk_1")
  Task            Task?     @relation(fields: [task_id], references: [task_id], onDelete: Cascade, onUpdate: NoAction, map: "Notification_ibfk_2")

  @@index([task_id], map: "task_id")
  @@index([user_id], map: "user_id")
}

model Project {
  project_id  Int       @id @default(autoincrement())
  name        String    @db.VarChar(255)
  description String?   @db.Text
  start_date  DateTime? @db.Date
  end_date    DateTime? @db.Date
  manager_id  Int?
  created_at  DateTime? @default(now()) @db.DateTime(0)
  User        User?     @relation(fields: [manager_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "Project_ibfk_1")
  Report      Report[]
  Task        Task[]

  @@index([manager_id], map: "manager_id")
}

model Report {
  report_id    Int       @id @default(autoincrement())
  project_id   Int?
  generated_at DateTime? @default(now()) @db.DateTime(0)
  content      String?   @db.Text
  Project      Project?  @relation(fields: [project_id], references: [project_id], onDelete: Cascade, onUpdate: NoAction, map: "Report_ibfk_1")

  @@index([project_id], map: "project_id")
}

model Role {
  role_id   Int    @id @default(autoincrement())
  role_name String @unique(map: "role_name") @db.VarChar(50)
  User      User[]
}

model Task {
  task_id          Int            @id @default(autoincrement())
  name             String         @db.VarChar(255)
  description      String?        @db.Text
  deadline         DateTime?      @db.Date
  status           Task_status?   @default(todo)
  project_id       Int?
  created_at       DateTime?      @default(now()) @db.DateTime(0)
  assigned_user_id Int?
  Notification     Notification[]
  Project          Project?       @relation(fields: [project_id], references: [project_id], onDelete: Restrict, onUpdate: Restrict, map: "Task_ibfk_1")
  User             User?          @relation(fields: [assigned_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_task_user")

  @@index([project_id], map: "fk_task_project")
  @@index([assigned_user_id], map: "fk_task_user")
}


model User {
  user_id       Int             @id @default(autoincrement())
  name          String          @db.VarChar(255)
  email         String          @unique(map: "email") @db.VarChar(255)
  password      String          @db.VarChar(255)
  role_id       Int
  department_id Int?
  status        User_status     @default(active)
  created_at    DateTime?       @default(now()) @db.DateTime(0)
  Notification  Notification[]
  Project       Project[]
  RefreshTokens RefreshTokens[]
  Task          Task[]
  Role          Role            @relation(fields: [role_id], references: [role_id], onDelete: NoAction, onUpdate: NoAction, map: "User_ibfk_1")
  Department    Department?     @relation(fields: [department_id], references: [department_id], onDelete: NoAction, onUpdate: NoAction, map: "User_ibfk_2")

  @@index([department_id], map: "department_id")
  @@index([role_id], map: "role_id")
}

enum User_status {
  active
  inactive
}

model RefreshTokens {
  id         Int       @id @default(autoincrement())
  token      String    @db.VarChar(500)
  user_id    Int
  expires_at DateTime  @db.DateTime(0)
  created_at DateTime? @default(now()) @db.DateTime(0)
  User       User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_refresh_tokens_user")

  @@index([user_id], map: "idx_user_id")
}

enum Task_status {
  todo
  in_progress
  done
}
